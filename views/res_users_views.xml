<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_realestate_voip" model="ir.ui.view">
        <field name="name">res.users.form.inherit.realestate.voip</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']//group[@name='other_preferences']" position="inside">
                <separator string="Real Estate VOIP" groups="real_estate.group_realestate_manager"/>
                <field name="asterisk_extension" groups="real_estate.group_realestate_manager"/>
                <field name="asterisk_caller_id" groups="real_estate.group_realestate_manager"/>
                <field name="realestate_commission_percent" groups="real_estate.group_realestate_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
